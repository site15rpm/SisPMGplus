/**
 * Função que instrumenta código JavaScript com logs apenas no início de funções nomeadas explicitamente
 * * @param {string} codigo - O código JavaScript a ser instrumentado
 * @return {string} O código com logs injetados
 */
function instrumentarCodigo(codigo) {
  if (!codigo || typeof codigo != 'string') return codigo;
  const regexFuncoes = /function\s+([a-zA-Z0-9_$]+)\s*\(([^)]*)\)\s*\{/g;

  function processarFuncao(match, nome, params) {
    if (nome.startsWith('_')) return match;
    const funcoesIgnorar = ['Ok', 'Cancel', 'Confirm', 'Close', 'Submit'];
    if (funcoesIgnorar.includes(nome)) return match;
    return `function ${nome}(${params}) {${logEntrada}`;
  }
  let codigoInstrumentado = codigo.replace(regexFuncoes, processarFuncao);
  
  return codigoInstrumentado;
}

/**
 * Versão modificada da função include que adiciona logs de forma simplificada
 * * @param {string} arquivo - Caminho do arquivo a ser incluído
 * @return {string} Conteúdo do arquivo processado com logs
 */
function includeComLogs(arquivo) {
  if (!arquivo) return '';
  
  try {
    let conteudo = HtmlService.createTemplateFromFile(arquivo).getRawContent();
    if (arquivo.endsWith('.js') || arquivo.includes('js/')) {
      if (conteudo.trim().startsWith('<script')) {
        const scriptMatch = conteudo.match(/\<script[^\>]*\>([\s\S]*?)\<\/script\>/);
        if (scriptMatch && scriptMatch[1]) {
          const scriptContent = scriptMatch[1];
          const instrumentedScript = instrumentarCodigo(scriptContent);
          conteudo = conteudo.replace(scriptMatch[1], instrumentedScript);
        }
      } else {
        conteudo = instrumentarCodigo(conteudo);
      }
    }
    
    return conteudo;
  } catch (e) {
    console.error('Erro ao incluir arquivo com logs:', e);
    return HtmlService.createTemplateFromFile(arquivo).getRawContent();
  }
}

/**
 * Função include original substituída pela versão com logs

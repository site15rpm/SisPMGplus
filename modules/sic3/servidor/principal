/**
 * Centraliza a obtenção de IDs do projeto a partir do PropertiesService.
 * Define os valores padrão se não existirem.
 * @returns {object} Objeto com os IDs do projeto.
 */
function getProjectIds() {
  const scriptProperties = PropertiesService.getScriptProperties();
  let spreadsheetId = scriptProperties.getProperty('SPREADSHEET_ID');
  let folderId = scriptProperties.getProperty('DRIVE_FOLDER_ID');

  if (!spreadsheetId) {
    spreadsheetId = '1vYll9MsmEpTyHxhztbVN4SxW27jtK8nXMlEKWSEUHHQ'; // Valor padrão
    scriptProperties.setProperty('SPREADSHEET_ID', spreadsheetId);
  }

  if (!folderId) {
    folderId = '1coa1DCSrNGiTJEbFshwUFjVAL7n-ZPxT'; // Valor padrão
    scriptProperties.setProperty('DRIVE_FOLDER_ID', folderId);
  }

  return {
    spreadsheetId: spreadsheetId,
    folderId: folderId
  };
}


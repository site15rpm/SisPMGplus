function irParaPainelLancamentos(authToken, municipio, convenio, ano, mes, acao) {
  const usuarioInfo = validateAuthToken(authToken);

  if (!usuarioInfo) {
    return HtmlService.createTemplateFromFile("html/login").evaluate().getContent();
  }
  
  const temPermissao = usuarioInfo.isAdmin || usuarioInfo.municipio === municipio;
  if (!temPermissao) {
    // Se não for admin e tentar acessar outro município, redireciona para o seu próprio.
    municipio = usuarioInfo.municipio;
  }
  
  const operacaoEditar = (acao === "editar" || acao === "lancar");
  if (operacaoEditar && !usuarioInfo.isAdmin) {
    const bloqueado = verificarStatusBloqueio(municipio, convenio, ano, mes) === "bloqueado";
    if (bloqueado) {
      acao = "visualizar"; // Força visualização se estiver bloqueado
    }
  }

  registrarOperacao("irParaPainelLancamentos", usuarioInfo.username, usuarioInfo.municipio, "acesso_lancamentos", `municipio: ${municipio}, acao: ${acao}`);

  var template = HtmlService.createTemplateFromFile("html/lancamentos");
  template.pUser = "html/lancamentos";
  template.mLog = usuarioInfo.isAdmin ? "admin" : usuarioInfo.municipio;
  template.nUser = usuarioInfo.username;
  template.municipio = municipio;
  template.convenio = convenio;
  template.ano = ano;
  template.mes = mes;
  template.acao = acao;
  template.authToken = authToken;
  template.idbase = getProjectIds().spreadsheetId;
  
  return template.evaluate().getContent();
}

/**
 * Função de navegação genérica, validando o token.
 */
function irpara(pName, pUser, mLog, nUser, municipio, ano, mes, acao, authToken) {
  const validatedUser = validateAuthToken(authToken);

  if (!validatedUser && pName != "html/login") {
    var template = HtmlService.createTemplateFromFile("html/login");
    return template.evaluate().getContent();
  }

  if (validatedUser && !validatedUser.isAdmin && municipio && municipio != validatedUser.municipio) {
    municipio = validatedUser.municipio; // Garante que o usuário não acesse dados de outro município
  }

  var template = HtmlService.createTemplateFromFile(pName);
  template.pUser = pUser;
  template.mLog = validatedUser ? (validatedUser.isAdmin ? "admin" : validatedUser.municipio) : mLog;
  template.nUser = validatedUser ? validatedUser.username : nUser;
  template.municipio = municipio;
  template.ano = ano;
  template.mes = mes;
  template.acao = acao;
  template.authToken = authToken;
  template.idbase = getProjectIds().spreadsheetId;

  return template.evaluate().getContent();
}



/**
 * Sistema robusto de controle de acesso baseado em permissões
 * Implementa verificações consistentes em todas as operações sensíveis
 */

/**
 * Middleware central de autorização para validar permissões de acesso
 * @param {string} authToken - Token de autenticação do usuário
 * @param {string} municipio - Município sendo acessado
 * @param {string} operacao - Tipo de operação (visualizar, editar, admin)
 * @return {object} Resultado da autorização com status e mensagem
 */
function autorizarAcesso(authToken, municipio, operacao, convenio, ano, mes) {
  try {
    if (!authToken) {
      return {
        autorizado: false,
        usuario: null,
        mensagem: "Necessário autenticar-se",
        codigoErro: "AUTH_REQUIRED"
      };
    }
    const usuario = validateAuthToken(authToken);
    if (!usuario) {
      return {
        autorizado: false,
        usuario: null,
        mensagem: "Token inválido ou expirado",
        codigoErro: "INVALID_TOKEN"
      };
    }
    switch (operacao) {
      case "visualizar":
        if (usuario.isAdmin || usuario.municipio == municipio) {
          return {
            autorizado: true,
            usuario: usuario,
            municipioPermitido: municipio
          };
        }
        break;
        
      case "editar":
        if (usuario.isAdmin || usuario.municipio == municipio) {
          const statusRelatorio = verificarStatusBloqueio(municipio, convenio, ano, mes);
          
          if (statusRelatorio == "bloqueado" && !usuario.isAdmin) {
            return {
              autorizado: false,
              usuario: usuario,
              mensagem: "Relatório bloqueado para edição",
              codigoErro: "REPORT_LOCKED"
            };
          }
          
          return {
            autorizado: true,
            usuario: usuario,
            municipioPermitido: municipio
          };
        }
        break;
        
      case "admin":
        if (usuario.isAdmin) {
          return {
            autorizado: true,
            usuario: usuario,
            municipioPermitido: municipio
          };
        }
        break;
        
      case "salvar":
        if (usuario.isAdmin || usuario.municipio == municipio) {
          const statusRelatorio = verificarStatusBloqueio(municipio, convenio, ano, mes);
          
          if (statusRelatorio == "bloqueado" && !usuario.isAdmin) {
            return {
              autorizado: false,
              usuario: usuario,
              mensagem: "Relatório bloqueado para edição",
              codigoErro: "REPORT_LOCKED"
            };
          }
          
          return {
            autorizado: true,
            usuario: usuario,
            municipioPermitido: municipio
          };
        }
        break;
    }
    registrarOperacao("autorizarAcesso", usuario.username, municipio, "access_denied", operacao);
    
    return {
      autorizado: false,
      usuario: usuario,
      mensagem: "Acesso negado a este recurso",
      codigoErro: "ACCESS_DENIED"
    };
    
  } catch (error) {
    console.error("Erro ao verificar autorização:", error);
    return {
      autorizado: false,
      usuario: null,
      mensagem: "Erro ao processar autorização",
      codigoErro: "AUTH_ERROR"
    };
  }
}

/**
 * Verifica se um relatório mensal está bloqueado para edição
 * @param {string} municipio - Município do relatório
 * @param {string} ano - Ano do relatório
 * @param {string} mes - Mês do relatório
 * @return {string} Status do relatório: "bloqueado" ou "desbloqueado"
 */
function verificarStatusBloqueio(municipio, convenio, ano, mes) {
  try {
    const ss = SpreadsheetApp.openById(getProjectIds().spreadsheetId);
    const sheet = ss.getSheetByName("obsgeral");
    const data = sheet.getDataRange().getValues();
    for (let i = 0; i < data.length; i++) {
      if (data[i][1] == municipio && String(data[i][2]) == String(convenio) && String(data[i][3]) == String(ano) && String(data[i][4]) == String(mes)) {
        return data[i][7] == "SIM" ? "bloqueado" : "desbloqueado";
      }
    }
    return "desbloqueado";
  } catch (error) {
    console.error("Erro ao verificar status de bloqueio:", error);
    return "desbloqueado";
  }
}


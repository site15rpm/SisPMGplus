function getNextItem99Code(authToken) {
  const local = "getNextItem99Code";
  const autorizacao = validateAuthToken(authToken);
  const username = autorizacao ? autorizacao.username : 'SYSTEM_UNAUTH';
  registrarOperacao(local, username, null, "get_code", "initiated");
  
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(30000);

    const ss = SpreadsheetApp.openById(getProjectIds().spreadsheetId);
    const sheet = ss.getSheetByName("item99");

    if (!sheet) {
      const newSheet = ss.insertSheet("item99");
      newSheet.appendRow(["timestamp", "municipio", "convenio", "ano", "mes", "item99_code", "descricao", "unidade_distribuicao", "elemento_despesa", "termos_busca", "status", "link_nota_fiscal"]);
      registrarOperacao(local, username, null, "get_code", "success_newsheet");
      return 990000001;
    }

    const data = sheet.getDataRange().getValues();
    let maxCode = 990000000;

    if (data.length > 1) {
      for (let i = 1; i < data.length; i++) {
        if (data[i][5]) {
          const currentCodeStr = String(data[i][5]).trim();
          if (currentCodeStr.startsWith("99") && /^\d+$/.test(currentCodeStr)) {
            const currentCode = parseInt(currentCodeStr, 10);
            if (!isNaN(currentCode) && currentCode > maxCode) {
              maxCode = currentCode;
            }
          }
        }
      }
    }
    
    const nextCode = maxCode + 1;
    registrarOperacao(local, username, null, "get_code", `success_next: ${nextCode}`);
    return nextCode;

  } catch (e) {
    registrarOperacao(local, username, null, "get_code", `error: ${e.message}`);
    console.error("[Código.gs] getNextItem99Code: Erro capturado:", e.toString(), e.stack);
    return 990000001; 
  } finally {
    if (lock) {
      lock.releaseLock();
    }
  }
}

/**
 * @function gerenciarItem99
 * @description Manages CRUD operations for Item 99 entries.
 * @param {string} operacao - The operation to perform ('excluir', 'editar').
 * @param {object} dados - Data object containing item details.
 * @returns {object} Result object with success status and message.
 */
function gerenciarItem99(operacao, dados) {
  const local = "gerenciarItem99";
  const { codigo, authToken } = dados;

  const autorizacao = validateAuthToken(authToken);
  if (!autorizacao) {
    return { success: false, message: "Autorização falhou." };
  }
  registrarOperacao(local, autorizacao.username, autorizacao.municipio, `item99_${operacao}`, `initiated: ${codigo}`);
  
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(30000);
    const ss = SpreadsheetApp.openById(getProjectIds().spreadsheetId);
    const item99Sheet = ss.getSheetByName("item99");

    if (!item99Sheet) {
      throw new Error("Aba 'item99' não encontrada.");
    }

    const item99Data = item99Sheet.getDataRange().getValues();
    let rowIndexItem99 = -1;
    for (let i = 1; i < item99Data.length; i++) {
      if (String(item99Data[i][5]) === String(codigo)) {
        rowIndexItem99 = i; // Store zero-based index
        break;
      }
    }

    if (rowIndexItem99 === -1) {
      registrarOperacao(local, autorizacao.username, autorizacao.municipio, `item99_${operacao}`, "not_found");
      return { success: false, message: `Item 99 com código ${codigo} não encontrado.` };
    }
    
    // CORREÇÃO 3: Lógica de exclusão consolidada para garantir a remoção de todas as planilhas.
    if (operacao === 'excluir') {
      const item99Row = item99Data[rowIndexItem99];
      const municipio = item99Row[1], convenio = item99Row[2], ano = item99Row[3], mes = item99Row[4];

      item99Sheet.getRange(rowIndexItem99 + 1, 11).setValue("excluido");

      ['principal', 'abastecimento', 'manutencao'].forEach(sheetName => {
        const sheet = ss.getSheetByName(sheetName);
        if (!sheet) return;

        const sheetData = sheet.getDataRange().getValues();
        for (let i = sheetData.length - 1; i >= 1; i--) {
            const row = sheetData[i];
            const codigoColuna = 6;
            if (String(row[1]) === String(municipio) && String(row[2]) === String(convenio) &&
                String(row[3]) === String(ano) && String(row[4]) === String(mes) &&
                String(row[codigoColuna]) === String(codigo)) {
                sheet.deleteRow(i + 1);
                break; 
            }
        }
      });
      
      atualizarObsGeralAposModificacao(ss, municipio, convenio, ano, mes);
      registrarOperacao(local, autorizacao.username, autorizacao.municipio, `item99_${operacao}`, "success");
      return { success: true };

    } else if (operacao === 'editar') {
      const { novosDados, fileInfo } = dados;
      
      const oldRowData = item99Sheet.getRange(rowIndexItem99 + 1, 1, 1, item99Sheet.getLastColumn()).getValues()[0];
      
      let newFileUrl = oldRowData[11]; // Coluna L (linkNotaFiscal)
      if (fileInfo && fileInfo.base64Data) {
        newFileUrl = uploadNotaFiscal(fileInfo, newFileUrl);
      }
      
      const updatedRowData = oldRowData;
      updatedRowData[0] = Utilities.formatDate(new Date(), "America/Sao_Paulo", "dd/MM/yyyy HH:mm:ss");
      updatedRowData[6] = novosDados.descricao;
      updatedRowData[7] = novosDados.unidade;
      updatedRowData[8] = novosDados.despesa;
      updatedRowData[11] = newFileUrl;
      
      item99Sheet.deleteRow(rowIndexItem99 + 1);
      
      item99Sheet.insertRowBefore(2);
      item99Sheet.getRange(2, 1, 1, updatedRowData.length).setValues([updatedRowData]).setNumberFormat("@STRING@");
      
      registrarOperacao(local, autorizacao.username, autorizacao.municipio, `item99_${operacao}`, "success");
      return { success: true, message: "Item 99 atualizado com sucesso." };
    }
  } catch (e) {
    registrarOperacao(local, autorizacao.username, autorizacao.municipio, `item99_${operacao}`, `error: ${e.message}`);
    return { success: false, message: "Erro interno do servidor." };
  } finally {
    if(lock) lock.releaseLock();
  }
}


function sincronizarItens99(authToken, spreadsheet, municipio, convenio, ano, mes, dadosPrincipais, timestamp, usuario) {
  const local = "sincronizarItens99";
  registrarOperacao(local, usuario.username, municipio, "sync_item99", "iniciada");
  console.log(`[sincronizarItens99] Iniciando sincronização para ${municipio}/${convenio} - ${mes}/${ano}`);

  const item99Sheet = spreadsheet.getSheetByName("item99");
  if (!item99Sheet) {
    throw new Error("Aba 'item99' não encontrada.");
  }

  const item99AllData = item99Sheet.getDataRange().getValues();
  const headers = item99AllData.shift();
  const codigoColIdx = 5;
  const statusColIdx = 10;

  const sheetReportItems = new Map();
  item99AllData.forEach((row, index) => {
    if (String(row[1]) === municipio && String(row[2]) === String(convenio) && String(row[3]) === String(ano) && String(row[4]) === String(mes)) {
      sheetReportItems.set(String(row[codigoColIdx]), {
        rowIndex: index + 2,
        rowData: row
      });
    }
  });

  const clientItemCodes = new Set();
  const clientItems = dadosPrincipais.filter(row => {
    const code = String(row[1]);
    const isItem99 = code.startsWith("99") || code.startsWith("ITEM99P");
    if (isItem99 && !code.startsWith("ITEM99P")) {
      clientItemCodes.add(code);
    }
    return isItem99;
  });
  console.log('[sincronizarItens99] Itens 99 do cliente:', clientItems.length);

  const sheetCodes = new Set(sheetReportItems.keys());
  sheetCodes.forEach(code => {
    if (!clientItemCodes.has(code)) {
      const itemInfo = sheetReportItems.get(code);
      if (itemInfo && itemInfo.rowData[statusColIdx] != 'excluido') {
        item99Sheet.getRange(itemInfo.rowIndex, statusColIdx + 1).setValue("excluido");
        registrarOperacao(local, usuario.username, municipio, "soft_delete_item99", `code: ${code}`);
      }
    }
  });

  const mapeamentoCodigos = {};
  let proximoCodigo99 = null;

  for (const rowCliente of clientItems) {
    const codigoCliente = String(rowCliente[1]);
    const isNew = codigoCliente.startsWith("ITEM99P");

    console.log(`[sincronizarItens99] Processando item do cliente: Código ${codigoCliente}, Novo: ${isNew}`);
    if (isNew) {
      if (proximoCodigo99 === null) proximoCodigo99 = getNextItem99Code(authToken);
      const finalCode = String(proximoCodigo99++);
      mapeamentoCodigos[rowCliente[11]] = finalCode;

      let fileUrl = "";
      if (rowCliente[12] && rowCliente[13]) {
        const nomeArquivoSanitizado = String(rowCliente[2]).replace(/[^\w\s.-]/g, '_').substring(0, 50);
        fileUrl = uploadNotaFiscal({
          base64Data: rowCliente[12],
          mimeType: rowCliente[13],
          fileName: `${finalCode} - ${nomeArquivoSanitizado}`
        }, null);
      }
      
      let item99Info = {};
      console.log('[sincronizarItens99] Novo Item 99 - rowCliente[10] (item99Info string):', rowCliente[10]);
      try {
        if (rowCliente[10]) {
          item99Info = JSON.parse(rowCliente[10]);
          console.log('[sincronizarItens99] Novo Item 99 - item99Info parsed:', JSON.stringify(item99Info));
        }
      } catch (e) {
        console.error(`Falha ao fazer parse do item99Info para o item ${finalCode}. Conteúdo: ${rowCliente[10]}. Erro: ${e.message}`);
        registrarOperacao(local, usuario.username, municipio, "json_parse_error", `code: ${finalCode}`);
      }

      const termosDeBusca = (item99Info && typeof item99Info.searchTerms === 'string') ? item99Info.searchTerms : '';
      console.log('[sincronizarItens99] Novo Item 99 - Termos de busca a serem salvos:', termosDeBusca);

      const novaLinha = [
        timestamp, municipio, convenio, String(ano), mes, finalCode,
        String(rowCliente[2]), String(rowCliente[4]), String(rowCliente[3]),
        termosDeBusca,
        'pendente',
        fileUrl
      ];
      
      item99Sheet.insertRowAfter(1);
      const newRowRange = item99Sheet.getRange(2, 1, 1, novaLinha.length);
      newRowRange.setValues([novaLinha]);
      newRowRange.setNumberFormat("@STRING@");

    } else { // Edição de item existente
      const existingItem = sheetReportItems.get(codigoCliente);
      if (existingItem) {
        const rowIndex = existingItem.rowIndex;
        const existingRowData = existingItem.rowData;

        item99Sheet.getRange(rowIndex, 1).setValue(timestamp);
        item99Sheet.getRange(rowIndex, 7).setValue(String(rowCliente[2]));
        item99Sheet.getRange(rowIndex, 8).setValue(String(rowCliente[4]));
        item99Sheet.getRange(rowIndex, 9).setValue(String(rowCliente[3]));

        let fileUrl = existingRowData[11];
        if (rowCliente[12] && rowCliente[13]) {
          const nomeArquivoSanitizado = String(rowCliente[2]).replace(/[^\w\s.-]/g, '_').substring(0, 50);
          fileUrl = uploadNotaFiscal({
            base64Data: rowCliente[12],
            mimeType: rowCliente[13],
            fileName: `${codigoCliente} - ${nomeArquivoSanitizado}`
          }, fileUrl);
          item99Sheet.getRange(rowIndex, 12).setValue(fileUrl);
        }

        let item99Info = {};
        console.log(`[sincronizarItens99] EDIT: Raw item99Info string from client: ${rowCliente[10]}`);
        try {
            if (rowCliente[10]) {
                item99Info = JSON.parse(rowCliente[10]);
                console.log(`[sincronizarItens99] EDIT: Parsed item99Info:`, JSON.stringify(item99Info));
            }
        } catch(e) {
            console.error(`Falha ao fazer parse do item99Info para o item existente ${codigoCliente}. Conteúdo: ${rowCliente[10]}. Erro: ${e.message}`);
        }

        // CORREÇÃO: Apenas atualiza os termos de busca se novos termos forem fornecidos.
        if (item99Info && typeof item99Info.searchTerms === 'string' && item99Info.searchTerms.trim() !== '') {
          console.log(`[sincronizarItens99] EDIT: Updating search terms for ${codigoCliente} to: "${item99Info.searchTerms}"`);
          item99Sheet.getRange(rowIndex, 10).setValue(item99Info.searchTerms);
        } else {
          console.log(`[sincronizarItens99] EDIT: No new search terms provided for ${codigoCliente}. Preserving existing value: "${existingRowData[9]}"`);
        }

        if (existingRowData[statusColIdx] === 'excluido') {
          item99Sheet.getRange(rowIndex, statusColIdx + 1).setValue('pendente');
        }
      }
    }
  }

  if (item99Sheet.getLastRow() > 1) {
    const rangeToSort = item99Sheet.getRange(2, 1, item99Sheet.getLastRow() - 1, item99Sheet.getLastColumn());
    rangeToSort.sort({ column: 6, ascending: false }); // Coluna F (item99_code)
  }

  console.log('[sincronizarItens99] Sincronização concluída.');
  return {
    success: true,
    mapeamento: mapeamentoCodigos
  };
}



function sanitizeData(data) {
  if (typeof data === 'string') {
    return data.replace(/\u00A0/g, ' ');
  }
  if (Array.isArray(data)) {
    return data.map(sanitizeData);
  }
  if (typeof data === 'object' && data !== null) {
    return Object.keys(data).reduce((acc, key) => {
      acc[key] = sanitizeData(data[key]);
      return acc;
    }, {});
  }
  return data;
}

function uploadNotaFiscal(fileObject, existingFileUrl = null) {
  try {
    if (existingFileUrl) {
      try {
        const fileId = existingFileUrl.match(/id=([^&]+)/)[1];
        if (fileId) {
          DriveApp.getFileById(fileId).setTrashed(true);
        }
      } catch (e) {
        console.error("Não foi possível excluir o arquivo antigo: " + e.toString());
        // Continua mesmo se a exclusão falhar
      }
    }
    
    const { base64Data, mimeType, fileName } = fileObject;
    if (!base64Data || !mimeType || !fileName) {
      throw new Error("Dados do arquivo inválidos para upload.");
    }

    const folderId = getProjectIds().folderId; // ID da pasta de destino
    const folder = DriveApp.getFolderById(folderId);
    
    const decoded = Utilities.base64Decode(base64Data, Utilities.Charset.UTF_8);
    const blob = Utilities.newBlob(decoded, mimeType, fileName);
    
    const file = folder.createFile(blob);
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
    
    return file.getUrl();
  } catch (error) {
    console.error("Erro ao fazer upload da nota fiscal:", error);
    return "";
  }
}


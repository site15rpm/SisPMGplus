var marcadoresEspaco = ['&', '~', '^', '%', '´', '`'];

function embaralharMarcadoresEspaco() {
  for (var i = marcadoresEspaco.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var temp = marcadoresEspaco[i];
    marcadoresEspaco[i] = marcadoresEspaco[j];
    marcadoresEspaco[j] = temp;
  }
}

function marcadorEspacoAleatorio(index) {
  return marcadoresEspaco[index % marcadoresEspaco.length];
}

function codificar(texto) {
  var resultado = '';
  var totalCaracteres = todosCaracteres.length;
  embaralharMarcadoresEspaco();

  for (var i = 0; i < texto.length; i++) {
    var char = texto[i];
    var posicao = todosCaracteres.indexOf(char);

    if (char === ' ') {
      resultado += marcadorEspacoAleatorio(i);
    } else if (posicao !== -1) {
      var novaPosicao = (posicao + 11) % totalCaracteres;
      resultado += todosCaracteres[novaPosicao];
    } else {
      resultado += char;
    }
  }
  return resultado;
}

function decodificar(textoCodificado) {
  var resultado = '';
  var totalCaracteres = todosCaracteres.length;

  for (var i = 0; i < textoCodificado.length; i++) {
    var char = textoCodificado[i];

    if (marcadoresEspaco.includes(char)) {
      resultado += ' ';
    } else {
      var posicao = todosCaracteres.indexOf(char);
      if (posicao !== -1) {
        var novaPosicao = (posicao - 11 + totalCaracteres) % totalCaracteres;
        resultado += todosCaracteres[novaPosicao];
      } else {
        resultado += char;
      }
    }
  }
  return resultado;
}

function criarTriggerBloqueioMensal() {
  // Primeiro, deleta qualquer trigger existente para essa função para evitar duplicações
  deletarTriggersBloqueio();
  
  // Cria o novo trigger para rodar todo dia 21 (anteriormente 16) às 3 da manhã
  ScriptApp.newTrigger("bloquearRelatoriosAntigosAutomaticamente")
    .timeBased()
    .onMonthDay(21)
    .atHour(3)
    .create();

  SpreadsheetApp.getUi().alert('Sucesso!', 'O gatilho para bloquear relatórios antigos no dia 21 de cada mês, às 3h da manhã, foi criado com sucesso.', SpreadsheetApp.getUi().ButtonSet.OK);
}

function deletarTriggersBloqueio() {
  const triggers = ScriptApp.getProjectTriggers();
  let deletados = 0;
  for (const trigger of triggers) {
    if (trigger.getHandlerFunction() === "bloquearRelatoriosAntigosAutomaticamente") {
      ScriptApp.deleteTrigger(trigger);
      deletados++;
    }
  }

  if (deletados > 0) {
    SpreadsheetApp.getUi().alert('Sucesso!', `${deletados} gatilho(s) de bloqueio foram removidos.`, SpreadsheetApp.getUi().ButtonSet.OK);
  } else {
    SpreadsheetApp.getUi().alert('Aviso', 'Nenhum gatilho de bloqueio para remover foi encontrado.', SpreadsheetApp.getUi().ButtonSet.OK);
  }
}
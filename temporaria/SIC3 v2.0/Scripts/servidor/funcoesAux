function salvarArquivoNoDrive(content) {
  const timestamp = new Date().toISOString().replace(/[-:]/g, '').replace('T', '-').split('.')[0];
  const filename = 'Script_AnexoD_TESTE_' + timestamp;
  const folderId = '1DxeqzzwhKJc736kYMN1iVY2T-Yy3tfuS';
  
  try {
    const doc = DocumentApp.create(filename);
    const body = doc.getBody();
    
    const chunkSize = 450000;
    for (let i = 0; i < content.length; i += chunkSize) {
      const chunk = content.substring(i, Math.min(i + chunkSize, content.length));
      body.appendParagraph(chunk);
    }
    
    doc.saveAndClose();
    
    const docFile = DriveApp.getFileById(doc.getId());
    const folder = DriveApp.getFolderById(folderId);
    docFile.moveTo(folder);
    
    return true;
  } catch (error) {
    throw new Error('Erro ao salvar arquivo no Drive: ' + error.message);
  }
}


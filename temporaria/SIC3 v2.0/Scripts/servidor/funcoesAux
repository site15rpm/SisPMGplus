function removerAcentosTexto() {
  var planilha = SpreadsheetApp.getActiveSpreadsheet();
  var abaAtiva = planilha.getActiveSheet();
  var intervalo = abaAtiva.getDataRange();
  var valores = intervalo.getValues();

  var removerAcentos = texto => texto.normalize("NFD").replace(/[\u0300-\u036f]/g, "");

  for (var i = 1; i < valores.length; i++) {
    for (var j = 0; j < valores[i].length; j++) {
      if (typeof valores[i][j] === 'string') {
        valores[i][j] = removerAcentos(valores[i][j]);
      }
    }
  }
  intervalo.setValues(valores);
}

function removerAcentosEConverterCaixaAlta() {
  var planilha = SpreadsheetApp.getActiveSpreadsheet();
  var abaAtiva = planilha.getActiveSheet();
  var intervalo = abaAtiva.getDataRange();
  var valores = intervalo.getValues();

  var removerAcentos = texto => texto.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase().replace(/Ç/g, "C");

  for (var i = 1; i < valores.length; i++) {
    for (var j = 0; j < valores[i].length; j++) {
      if (typeof valores[i][j] === 'string') {
        valores[i][j] = removerAcentos(valores[i][j]);
      }
    }
  }
  intervalo.setValues(valores);
}


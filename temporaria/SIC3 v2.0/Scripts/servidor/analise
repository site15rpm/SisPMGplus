};

// Cache global para evitar processamento duplicado
var cacheGlobalCaminhos = new Set();
var funcoesDefinidas = new Map();
var funcoesDuplicadas = new Set();

/**
 * Obtém todos os arquivos do projeto através da API
 */
function getProjectFiles() {
  try {
    const files = [];
    
    try {
      const projectId = ScriptApp.getScriptId();
      const url = `https://script.google.com/feeds/download/export?id=${projectId}&format=json`;
      const token = ScriptApp.getOAuthToken();
      const response = UrlFetchApp.fetch(url, {
        headers: { 'Authorization': 'Bearer ' + token },
        muteHttpExceptions: true,
        timeout: 30000
      });
      
      if (response.getResponseCode() !== 200) {
        Logger.log(`Erro ao obter arquivos do projeto. Código HTTP: ${response.getResponseCode()}`);
        return [];
      }
      
      const fileData = JSON.parse(response.getContentText());
      Logger.log(`Dados obtidos da API: ${JSON.stringify(fileData, null, 2)}`);
      
      if (fileData && fileData.files) {
        fileData.files.forEach(file => {
          if (!file || !file.name || !file.type) return;
          
           const fileName = file.name.includes('/') ? file.name.split('/').pop() : file.name;
          const filePath = file.name;
          let isScript = false;
          let categoria = 'outros';
          
           if (file.type === "server_js" || filePath.toLowerCase().startsWith('js/') || filePath.toLowerCase().includes('/js/')) {
            isScript = true;
            categoria = 'javascript';
          } else if (file.type === "html" || filePath.toLowerCase().startsWith('html/') || filePath.toLowerCase().includes('/html/')) {
            categoria = 'html';
            if (file.source && contemTagsScript(file.source)) {
              isScript = true;
            }
          } else if (filePath.toLowerCase().startsWith('css/') || filePath.toLowerCase().includes('/css/') || fileName.toLowerCase().endsWith('.css')) {
            categoria = 'css';
          }
          
          files.push({
            name: fileName,
            fullPath: filePath,
            type: file.type,
            categoria: categoria,
            source: file.source || "",
            isJs: isScript
          });
        });
      }
      
      Logger.log(`Total de arquivos processados: ${files.length}`);
      Logger.log(`Arquivos JS encontrados: ${files.filter(f => f.isJs).length}`);
      
    } catch (error) {
      Logger.log(`Erro ao acessar a API: ${error}`);
      return [];
    }
    
    return files;
  } catch (error) {
    Logger.log(`Erro geral ao obter arquivos do projeto: ${error}`);
    return [];
  }
}

/**
 * Verifica se conteúdo HTML contém tags script
 */
function contemTagsScript(conteudo) {
  if (!conteudo || typeof conteudo !== 'string') return false;
  
  const scriptTags = [
    /<script\b[^>]*>/i,
    /<script\s*>/i,
    /<\/script>/i
  ];
  
  return scriptTags.some(regex => regex.test(conteudo));
}


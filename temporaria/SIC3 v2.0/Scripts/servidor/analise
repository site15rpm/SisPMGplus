function extrairConteudoFuncao(codigoFonte, nomeFuncao, posicaoInicial) {
  if (!codigoFonte || !nomeFuncao) return "";
  
  try {
    let posicaoInicio = posicaoInicial || 0;
    
    // Se não temos posição inicial, procurar pela função
    if (!posicaoInicial) {
      const nomeFuncaoEscaped = nomeFuncao.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const padroesBusca = [
        new RegExp(`function\\s+${nomeFuncaoEscaped}\\s*\\(`, 'g'),
        new RegExp(`(?:const|let|var)\\s+${nomeFuncaoEscaped}\\s*=\\s*function`, 'g'),
        new RegExp(`(?:const|let|var)\\s+${nomeFuncaoEscaped}\\s*=\\s*\\(`, 'g'),
        new RegExp(`${nomeFuncaoEscaped}\\s*:\\s*function`, 'g'),
        new RegExp(`${nomeFuncaoEscaped}\\s*\\(.*\\)\\s*\\{`, 'g')
      ];
      
      for (const padrao of padroesBusca) {
        padrao.lastIndex = 0;
        const match = padrao.exec(codigoFonte);
        if (match) {
          posicaoInicio = match.index;
          break;
        }
      }
    }
    
    // Encontrar a abertura da chave
    let indexAbreChave = codigoFonte.indexOf('{', posicaoInicio);
    if (indexAbreChave === -1) {
      // Tentar com arrow function
      const arrowIndex = codigoFonte.indexOf('=>', posicaoInicio);
      if (arrowIndex !== -1) {
        indexAbreChave = codigoFonte.indexOf('{', arrowIndex);
      }
    }
    
    if (indexAbreChave === -1) {
      Logger.log(`Não foi possível encontrar abertura de chave para função ${nomeFuncao}`);
      return "";
    }
    
    // Contar chaves para encontrar o final da função
    let nivel = 1;
    let indexAtual = indexAbreChave + 1;
    let dentroString = false;
    let charAnterior = '';
    
    while (nivel > 0 && indexAtual < codigoFonte.length) {
      const char = codigoFonte[indexAtual];
      
      // Detectar strings para ignorar chaves dentro delas
      if ((char === '"' || char === "'") && charAnterior !== '\\') {
        dentroString = !dentroString;
      }
      
      if (!dentroString) {
        if (char === '{') {
          nivel++;
        } else if (char === '}') {
          nivel--;
        }
      }
      
      charAnterior = char;
      indexAtual++;
    }
    
    if (nivel === 0) {
      const conteudo = codigoFonte.substring(indexAbreChave + 1, indexAtual - 1);
      Logger.log(`Conteúdo extraído para ${nomeFuncao}: ${conteudo.length} caracteres`);
      return conteudo;
    } else {
      Logger.log(`Não foi possível fechar chaves para função ${nomeFuncao}`);
      return "";
    }
    
  } catch (error) {
    Logger.log(`Erro ao extrair conteúdo da função ${nomeFuncao}: ${error}`);
    return "";
  }
}


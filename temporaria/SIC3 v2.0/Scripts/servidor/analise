/**
 * CORREÇÃO 2: Executa a análise para arquivos selecionados
 */
function executarAnaliseArquivos(arquivosSelecionados) {
  try {
    Logger.log("=== INICIANDO ANÁLISE ===");
    Logger.log("Arquivos selecionados: " + JSON.stringify(arquivosSelecionados));
    
    // Obter todos os arquivos do projeto
    const todosArquivos = getProjectFiles();
    Logger.log(`Total de arquivos no projeto: ${todosArquivos.length}`);
    
    // Filtrar arquivos selecionados para análise
    let arquivosParaAnalise;
    if (arquivosSelecionados.includes('todos')) {
      arquivosParaAnalise = todosArquivos.filter(arquivo => arquivo.isJs);
      Logger.log("Analisando TODOS os arquivos JS");
    } else {
      arquivosParaAnalise = todosArquivos.filter(arquivo => 
        arquivo.isJs && arquivosSelecionados.includes(arquivo.name)
      );
      Logger.log("Analisando arquivos específicos");
    }
    
    Logger.log(`Arquivos selecionados para análise: ${arquivosParaAnalise.length}`);
    
    if (arquivosParaAnalise.length === 0) {
      return { sucesso: false, erro: "Nenhum arquivo JavaScript encontrado para análise" };
    }
    
    // Reset dos caches e mapas globais
    cacheGlobalCaminhos = new Set();
    funcoesDefinidas = new Map();
    funcoesDuplicadas = new Set();
    
    // Primeiro passo: mapear todas as funções definidas no projeto
    Logger.log("=== MAPEANDO FUNÇÕES DEFINIDAS ===");
    mapearFuncoesDefinidas(todosArquivos);
    
    // Segundo passo: analisar ramificações por arquivo
    Logger.log("=== ANALISANDO RAMIFICAÇÕES ===");
    const resultados = [];
    
    arquivosParaAnalise.forEach((arquivo, index) => {
      Logger.log(`[${index + 1}/${arquivosParaAnalise.length}] Analisando arquivo: ${arquivo.name}`);
      
      try {
        const pontosEntrada = encontrarPontosEntrada(arquivo.source, arquivo.name);
        Logger.log(`Pontos de entrada encontrados em ${arquivo.name}: ${pontosEntrada.length}`);
        
        if (pontosEntrada.length === 0) {
          Logger.log(`Nenhum ponto de entrada encontrado em ${arquivo.name}`);
          // Registrar arquivo sem pontos de entrada
          registrarRamificacao({
            arquivo: arquivo.name,
            pontoEntrada: "[Sem pontos de entrada]",
            funcaoInicial: "[N/A]",
            ramificacao: [],
            status: "sem_entrada",
            origem: "SEM_ENTRADA"
          }, resultados);
        } else {
          pontosEntrada.forEach((pontoEntrada, peIndex) => {
            Logger.log(`  Analisando ponto de entrada ${peIndex + 1}: ${pontoEntrada.nome}`);
            analisarRamificacoesCompletas(
              pontoEntrada, 
              arquivo.name, 
              todosArquivos, 
              resultados
            );
          });
        }
      } catch (error) {
        Logger.log(`Erro ao analisar arquivo ${arquivo.name}: ${error}`);
      }
    });
    
    // Gerar estatísticas finais
    const estatisticas = gerarEstatisticasCompletas(resultados, todosArquivos);
    
    Logger.log(`=== ANÁLISE CONCLUÍDA ===`);
    Logger.log(`Total de ramificações encontradas: ${resultados.length}`);
    
    return {
      sucesso: true,
      dados: resultados,
      estatisticas: estatisticas
    };
  } catch (error) {
    Logger.log('Erro na análise: ' + error);
    Logger.log('Stack trace: ' + error.stack);
    return { sucesso: false, erro: error.toString() };
  }
}

/**
 * Mapeia todas as funções definidas no projeto
 */
function mapearFuncoesDefinidas(arquivos) {
  funcoesDefinidas.clear();
  funcoesDuplicadas.clear();
  
  Logger.log("Mapeando funções definidas...");
  
  arquivos.forEach(arquivo => {
    if (!arquivo.isJs || !arquivo.source) return;
    
    Logger.log(`Processando funções do arquivo: ${arquivo.name}`);
    const funcoes = extrairDefinicoesFuncoes(arquivo.source);
    Logger.log(`Funções encontradas em ${arquivo.name}: ${funcoes.length}`);
    
    funcoes.forEach(funcao => {
      if (funcoesDefinidas.has(funcao.nome)) {
        // Função já existe - marcar como duplicada
        funcoesDuplicadas.add(funcao.nome);
        
        // Adicionar informação de duplicata
        const existente = funcoesDefinidas.get(funcao.nome);
        existente.duplicadas = existente.duplicadas || [];
        existente.duplicadas.push({
          arquivo: arquivo.name,
          linha: funcao.linha
        });
        
        Logger.log(`Função duplicada encontrada: ${funcao.nome} em ${arquivo.name}`);
      } else {
        // Primeira definição da função
        funcoesDefinidas.set(funcao.nome, {
          nome: funcao.nome,
          arquivo: arquivo.name,
          conteudo: funcao.conteudo,
          linha: funcao.linha,
          duplicadas: []
        });
      }
    });
  });
  
  Logger.log(`Mapeamento concluído: ${funcoesDefinidas.size} funções únicas, ${funcoesDuplicadas.size} duplicadas`);
}

/**
 * CORREÇÃO 2.1: Extrai definições de funções com padrões mais abrangentes
 */
function extrairDefinicoesFuncoes(codigoFonte) {
  const funcoes = [];
  
  if (!codigoFonte || typeof codigoFonte !== 'string') {
    return funcoes;
  }
  
  Logger.log(`Extraindo definições de funções de código com ${codigoFonte.length} caracteres`);
  
  // Remove comentários para evitar falsos positivos
  let codigoLimpo = codigoFonte
    .replace(/\/\/.*$/gm, '')
    .replace(/\/\*[\s\S]*?\*\//g, '');
  
  // Padrões mais abrangentes para diferentes tipos de definição de função
  const padroes = [
    // function nome() { ... } - Declaração tradicional
    {
      regex: /function\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\s*\([^)]*\)\s*\{/g,
      grupo: 1,
      tipo: "function_declaration"
    },
    // const/let/var nome = function() { ... } - Expressão de função
    {
      regex: /(?:const|let|var)\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\s*=\s*function\s*\([^)]*\)\s*\{/g,
      grupo: 1,
      tipo: "function_expression"
    },
    // const/let/var nome = () => { ... } - Arrow function
    {
      regex: /(?:const|let|var)\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\s*=\s*\([^)]*\)\s*=>\s*\{/g,
      grupo: 1,
      tipo: "arrow_function"
    },
    // const/let/var nome = arg => { ... } - Arrow function sem parênteses
    {
      regex: /(?:const|let|var)\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\s*=\s*[a-zA-Z_$][a-zA-Z0-9_$]*\s*=>\s*\{/g,
      grupo: 1,
      tipo: "arrow_function_single"
    },
    // nome: function() { ... } - Método em objeto literal
    {
      regex: /([a-zA-Z_$][a-zA-Z0-9_$]*)\s*:\s*function\s*\([^)]*\)\s*\{/g,
      grupo: 1,
      tipo: "object_method"
    },
    // nome() { ... } - Método em classe ou objeto (ES6)
    {
      regex: /([a-zA-Z_$][a-zA-Z0-9_$]*)\s*\([^)]*\)\s*\{/g,
      grupo: 1,
      tipo: "method_shorthand"
    },
    // nome: () => { ... } - Arrow function em objeto
    {
      regex: /([a-zA-Z_$][a-zA-Z0-9_$]*)\s*:\s*\([^)]*\)\s*=>\s*\{/g,
      grupo: 1,
      tipo: "object_arrow_method"
    }
  ];
  
  let totalDefinicoes = 0;
  
  padroes.forEach((padrao, index) => {
    padrao.regex.lastIndex = 0;
    let match;
    let matchesThisPattern = 0;
    
    while ((match = padrao.regex.exec(codigoLimpo)) !== null) {
      const nomeFuncao = match[padrao.grupo];
      
      // Validações básicas
      if (!nomeFuncao || nomeFuncao.length < 2) continue;
      
      // Ignorar palavras-chave JavaScript
      const palavrasChave = new Set(['if', 'for', 'while', 'do', 'switch', 'catch', 'try', 'else', 'return']);
      if (palavrasChave.has(nomeFuncao.toLowerCase())) continue;
      
      // Encontrar linha da definição
      const posicao = match.index;
      const textoAteMatch = codigoLimpo.substring(0, posicao);
      const numeroLinha = textoAteMatch.split('\n').length;
      
      // Extrair conteúdo da função
      const conteudo = extrairConteudoFuncao(codigoLimpo, nomeFuncao, posicao);
      
      // Só incluir se tem conteúdo significativo
      if (conteudo && conteudo.trim().length > 5) {
        Logger.log(`✓ Função definida [${padrao.tipo}]: ${nomeFuncao} (linha ${numeroLinha}, ${conteudo.length} chars)`);
        
        funcoes.push({
          nome: nomeFuncao,
          conteudo: conteudo,
          linha: numeroLinha,
          tipo: padrao.tipo
        });
        
        totalDefinicoes++;
        matchesThisPattern++;
      }
      
      // Evitar loop infinito
      if (matchesThisPattern > 20) {
        Logger.log(`Muitas definições encontradas com padrão ${index}, limitando...`);
        break;
      }
    }
  });
  
  Logger.log(`=== RESUMO EXTRAÇÃO DE DEFINIÇÕES ===`);
  Logger.log(`Total de definições encontradas: ${totalDefinicoes}`);
  Logger.log(`Funções definidas: [${funcoes.map(f => f.nome).join(', ')}]`);
  
  // Remover duplicatas (mesmo nome)
  const funcoesUnicas = [];
  const nomesVistos = new Set();
  
  funcoes.forEach(funcao => {
    if (!nomesVistos.has(funcao.nome)) {
      nomesVistos.add(funcao.nome);
      funcoesUnicas.push(funcao);
    } else {
      Logger.log(`⚠ Função duplicada ignorada: ${funcao.nome}`);
    }
  });
  
  Logger.log(`Funções únicas após remoção de duplicatas: ${funcoesUnicas.length}`);
  
  return funcoesUnicas;
}

/**
 * CORREÇÃO 2.2: Encontra pontos de entrada com padrões melhorados e detecção mais ampla
 */
function encontrarPontosEntrada(codigoFonte, nomeArquivo) {
  const pontosEntrada = [];
  
  if (!codigoFonte || typeof codigoFonte !== 'string') {
    Logger.log(`Código fonte vazio ou inválido para ${nomeArquivo}`);
    return pontosEntrada;
  }
  
  Logger.log(`Procurando pontos de entrada em ${nomeArquivo} (${codigoFonte.length} caracteres)`);
  
  // Remove comentários mas preserva estrutura
  let codigoLimpo = codigoFonte
    .replace(/\/\/.*$/gm, '')
    .replace(/\/\*[\s\S]*?\*\//g, '');
  
  // AMPLIAÇÃO: Padrões para pontos de entrada incluindo funções trigger do GAS
  const padroesPontosEntrada = [
    // Funções trigger específicas do Google Apps Script (ALTA PRIORIDADE)
    {
      regex: /function\s+(doGet|doPost|onOpen|onEdit|onInstall|onFormSubmit|onSelectionChange|executarAnaliseArquivos|criarPaginaSelecaoArquivos|montarHtmlSelecaoArquivos)\s*\([^)]*\)\s*\{([\s\S]*?)\n\}/g,
      nome: "GAS Function",
      tipo: "gas_function",
      nomeDoGrupo: 1,
      conteudoGrupo: 2
    },
    // IIFE - Immediately Invoked Function Expression
    {
      regex: /\(\s*function\s*\([^)]*\)\s*\{([\s\S]*?)\}\s*\)\s*\([^)]*\)\s*;?/g,
      nome: "IIFE",
      tipo: "autoexecucao",
      conteudoGrupo: 1
    },
    // jQuery document.ready
    {
      regex: /\$\s*\(\s*document\s*\)\s*\.\s*ready\s*\(\s*function\s*\([^)]*\)\s*\{([\s\S]*?)\}\s*\)\s*;?/g,
      nome: "$(document).ready",
      tipo: "autoexecucao",
      conteudoGrupo: 1
    },
    // jQuery shorthand
    {
      regex: /\$\s*\(\s*function\s*\([^)]*\)\s*\{([\s\S]*?)\}\s*\)\s*;?/g,
      nome: "$(function)",
      tipo: "autoexecucao",
      conteudoGrupo: 1
    },
    // window.onload
    {
      regex: /window\s*\.\s*onload\s*=\s*function\s*\([^)]*\)\s*\{([\s\S]*?)\}/g,
      nome: "window.onload",
      tipo: "autoexecucao",
      conteudoGrupo: 1
    },
    // DOMContentLoaded
    {
      regex: /document\s*\.\s*addEventListener\s*\(\s*['"]DOMContentLoaded['"]\s*,\s*function\s*\([^)]*\)\s*\{([\s\S]*?)\}\s*\)/g,
      nome: "DOMContentLoaded",
      tipo: "autoexecucao",
      conteudoGrupo: 1
    },
    // setTimeout/setInterval com função anônima
    {
      regex: /(?:setTimeout|setInterval)\s*\(\s*function\s*\([^)]*\)\s*\{([\s\S]*?)\}\s*,/g,
      nome: "setTimeout/setInterval",
      tipo: "timer",
      conteudoGrupo: 1
    },
    // Eventos addEventListener genéricos
    {
      regex: /addEventListener\s*\(\s*['"][^'"]+['"]\s*,\s*function\s*\([^)]*\)\s*\{([\s\S]*?)\}\s*\)/g,
      nome: "addEventListener",
      tipo: "event_listener",
      conteudoGrupo: 1
    },
    // NOVO: Funções que parecem ser pontos de entrada (começam com código no topo do arquivo)
    {
      regex: /^[\s]*(?:function\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\s*\([^)]*\)\s*\{([\s\S]*?)\n\})/m,
      nome: "Top Level Function",
      tipo: "top_level",
      nomeDoGrupo: 1,
      conteudoGrupo: 2
    }
  ];
  
  let totalMatches = 0;
  
  padroesPontosEntrada.forEach((padrao, index) => {
    padrao.regex.lastIndex = 0;
    let match;
    let matchesThisPattern = 0;
    
    while ((match = padrao.regex.exec(codigoLimpo)) !== null) {
      const nomePonto = padrao.nomeDoGrupo ? match[padrao.nomeDoGrupo] : padrao.nome;
      const conteudo = match[padrao.conteudoGrupo || 1] || '';
      
      // Filtrar funções muito pequenas (menos de 20 caracteres podem ser vazias)
      if (conteudo.trim().length < 10) {
        Logger.log(`Ponto de entrada ignorado (muito pequeno): ${nomePonto}`);
        continue;
      }
      
      Logger.log(`✓ Ponto de entrada encontrado [${index}]: ${nomePonto} (${conteudo.length} caracteres) - Tipo: ${padrao.tipo}`);
      
      pontosEntrada.push({
        nome: nomePonto,
        tipo: padrao.tipo,
        conteudo: conteudo,
        arquivo: nomeArquivo
      });
      
      matchesThisPattern++;
      totalMatches++;
      
      // Evitar loop infinito limitando matches por padrão
      if (matchesThisPattern > 10) {
        Logger.log(`Muitos matches para padrão ${index}, limitando...`);
        break;
      }
    }
  });
  
  // FALLBACK: Se não encontrou pontos de entrada tradicionais, procurar por qualquer função definida
  if (pontosEntrada.length === 0) {
    Logger.log(`Nenhum ponto de entrada tradicional encontrado em ${nomeArquivo}, procurando funções definidas...`);
    
    const funcoesTodoArquivo = extrairDefinicoesFuncoes(codigoLimpo);
    Logger.log(`Funções definidas encontradas: ${funcoesTodoArquivo.length}`);
    
    // Pegar as primeiras 3 funções como possíveis pontos de entrada
    funcoesTodoArquivo.slice(0, 3).forEach(funcao => {
      if (funcao.conteudo && funcao.conteudo.length > 20) {
        Logger.log(`✓ Usando função como ponto de entrada: ${funcao.nome}`);
        pontosEntrada.push({
          nome: `function_${funcao.nome}`,
          tipo: "function_fallback",
          conteudo: funcao.conteudo,
          arquivo: nomeArquivo
        });
      }
    });
  }
  
  Logger.log(`=== RESUMO PONTOS DE ENTRADA ===`);
  Logger.log(`Arquivo: ${nomeArquivo}`);
  Logger.log(`Total de pontos encontrados: ${pontosEntrada.length}`);
  pontosEntrada.forEach((pe, i) => {
    Logger.log(`  ${i+1}. ${pe.nome} (${pe.tipo}) - ${pe.conteudo.length} chars`);
  });
  
  return pontosEntrada;
}

/**
 * Analisa ramificações completas a partir de um ponto de entrada
 */
function analisarRamificacoesCompletas(pontoEntrada, arquivoAtual, todosArquivos, resultados) {
  Logger.log(`Analisando ponto de entrada: ${pontoEntrada.nome} em ${arquivoAtual}`);
  
  // Extrair funções iniciais do ponto de entrada (apenas funções do programador)
  const funcoesIniciais = extrairChamadasFuncao(pontoEntrada.conteudo);
  Logger.log(`Funções iniciais encontradas: ${funcoesIniciais.length} - [${funcoesIniciais.join(', ')}]`);
  
  if (funcoesIniciais.length === 0) {
    // Ponto de entrada sem chamadas - registrar como ramificação vazia
    registrarRamificacao({
      arquivo: arquivoAtual,
      pontoEntrada: pontoEntrada.nome,
      funcaoInicial: "[Sem chamadas]",
      ramificacao: [],
      status: "vazia",
      origem: "VAZIA"
    }, resultados);
    return;
  }
  
  // Para cada função inicial, rastrear ramificações
  funcoesIniciais.forEach(funcaoInicial => {
    Logger.log(`Rastreando ramificação iniciada por: ${funcaoInicial}`);
    rastrearRamificacao(
      funcaoInicial,
      arquivoAtual,
      pontoEntrada.nome,
      [],
      new Set(),
      todosArquivos,
      resultados
    );
  });
}

/**
 * Rastreia uma ramificação específica recursivamente
 */
function rastrearRamificacao(funcaoAtual, arquivoOrigem, pontoEntrada, caminhoAtual, visitadas, todosArquivos, resultados) {
  Logger.log(`Rastreando função: ${funcaoAtual} (caminho atual: ${caminhoAtual.length})`);
  
  // Verificar se é uma referência circular
  if (visitadas.has(funcaoAtual)) {
    Logger.log(`Referência circular detectada: ${funcaoAtual}`);
    registrarRamificacao({
      arquivo: arquivoOrigem,
      pontoEntrada: pontoEntrada,
      funcaoInicial: caminhoAtual[0] || funcaoAtual,
      ramificacao: [...caminhoAtual, `${funcaoAtual} (circular)`],
      status: "circular",
      origem: "CIRCULAR"
    }, resultados);
    return;
  }
  
  // Adicionar função ao caminho atual
  const novoCaminho = [...caminhoAtual, funcaoAtual];
  const novasVisitadas = new Set(visitadas);
  novasVisitadas.add(funcaoAtual);
  
  // Verificar se a função está definida
  const definicaoFuncao = funcoesDefinidas.get(funcaoAtual);
  
  if (!definicaoFuncao) {
    // Função indefinida
    Logger.log(`Função indefinida: ${funcaoAtual}`);
    registrarRamificacao({
      arquivo: arquivoOrigem,
      pontoEntrada: pontoEntrada,
      funcaoInicial: novoCaminho[0],
      ramificacao: novoCaminho,
      status: "indefinida",
      origem: "INDEFINIDA"
    }, resultados);
    return;
  }
  
  // Função definida - extrair próximas chamadas
  const proximasChamadas = extrairChamadasFuncao(definicaoFuncao.conteudo);
  Logger.log(`Próximas chamadas de ${funcaoAtual}: ${proximasChamadas.length} - [${proximasChamadas.join(', ')}]`);
  
  if (proximasChamadas.length === 0) {
    // Fim da ramificação
    Logger.log(`Fim da ramificação para: ${funcaoAtual}`);
    registrarRamificacao({
      arquivo: arquivoOrigem,
      pontoEntrada: pontoEntrada,
      funcaoInicial: novoCaminho[0],
      ramificacao: novoCaminho,
      status: "definida",
      origem: definicaoFuncao.arquivo
    }, resultados);
    return;
  }
  
  // Continuar rastreamento para cada chamada
  proximasChamadas.forEach(proximaChamada => {
    rastrearRamificacao(
      proximaChamada,
      arquivoOrigem,
      pontoEntrada,
      novoCaminho,
      novasVisitadas,
      todosArquivos,
      resultados
    );
  });
}

/**
 * Registra uma ramificação nos resultados
 */
function registrarRamificacao(ramificacao, resultados) {
  // Gerar assinatura única para evitar duplicatas
  const assinatura = `${ramificacao.arquivo}|${ramificacao.pontoEntrada}|${ramificacao.ramificacao.join('->')}`;
  
  if (cacheGlobalCaminhos.has(assinatura)) {
    return;
  }
  
  cacheGlobalCaminhos.add(assinatura);
  
  // Criar objeto de resultado conforme especificação
  const resultado = {
    arquivo: ramificacao.arquivo,
    pontoEntrada: ramificacao.pontoEntrada,
    funcaoInicial: ramificacao.funcaoInicial,
    origem: ramificacao.origem,
    status: ramificacao.status
  };
  
  // Adicionar níveis da ramificação (exceto a função inicial)
  for (let i = 1; i < ramificacao.ramificacao.length; i++) {
    resultado[`nivel${i}`] = ramificacao.ramificacao[i];
  }
  
  resultados.push(resultado);
  Logger.log(`Ramificação registrada: ${assinatura}`);
}


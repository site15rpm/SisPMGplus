    'fetch', 'fetchAll', 'request', 'getContentText', 'getBlob', 'getHeaders',
    'getResponseCode', 'getAllHeaders', 'getResponseText',
    'sendEmail', 'getInboxThreads', 'search', 'markAsRead', 'markAsUnread',
    'addLabel', 'removeLabel', 'moveToTrash', 'moveToInbox',
    'createEvent', 'getEvents', 'getEventsForDay', 'deleteEvent',
    'getMyCalendars', 'getCalendarById', 'getDefaultCalendar',
    'lock', 'waitLock', 'releaseLock', 'hasLock', 'tryLock',
    'getProperty', 'setProperty', 'deleteProperty', 'getKeys', 'getProperties',
    'setProperties', 'deleteAllProperties',
    'sleep', 'getUuid', 'newBlob', 'base64Encode', 'base64Decode',
    'computeDigest', 'computeHmacSignature', 'getAuthToken', 'getScriptId',
    'formatDate', 'formatString', 'parseCsv', 'jsonParse', 'jsonStringify',
    
    // Outros métodos comuns
    'toString', 'valueOf', 'hasOwnProperty', 'isPrototypeOf', 'propertyIsEnumerable',
    'toLocaleString', 'constructor', 'length', 'prototype', 'apply', 'call', 'bind',
    'log', 'error', 'warn', 'info', 'debug',
    
    // Palavras-chave JavaScript
    'return', 'if', 'else', 'for', 'while', 'do', 'switch', 'case', 'break', 'continue',
    'function', 'var', 'let', 'const', 'try', 'catch', 'finally', 'throw', 'class', 'extends'
  ]);
  
  // Remove comentários mas preserva estrutura
  let codigoLimpo = codigoFonte
    .replace(/\/\/.*$/gm, '')
    .replace(/\/\*[\s\S]*?\*\//g, '')
    .replace(/["'](?:[^"'\\]|\\.)*["']/g, '""');
  
  // MÚLTIPLOS PADRÕES para capturar diferentes tipos de chamadas
  const padroesChamadas = [
    // Chamadas simples: funcao()
    /\b([a-zA-Z_$][a-zA-Z0-9_$]*)\s*\(/g,
    
    // Chamadas com objeto: objeto.funcao()
    /\.([a-zA-Z_$][a-zA-Z0-9_$]*)\s*\(/g,
    
    // Chamadas dentro de expressões: var x = funcao()
    /=\s*([a-zA-Z_$][a-zA-Z0-9_$]*)\s*\(/g,
    
    // Chamadas como argumentos: outraFuncao(funcao())
    /\(\s*([a-zA-Z_$][a-zA-Z0-9_$]*)\s*\(/g
  ];
  
  let totalMatches = 0;
  
  padroesChamadas.forEach((regex, patternIndex) => {
    regex.lastIndex = 0;
    let match;
    let matchesThisPattern = 0;
    
    while ((match = regex.exec(codigoLimpo)) !== null) {
      const funcao = match[1];
      
      // Validações para incluir a função
      if (funcao && 
          funcao.length > 1 && 
          !funcoesNativas.has(funcao) &&
          !funcao.match(/^\d/) &&
          funcoesDefinidas && 
          funcoesDefinidas.has(funcao)) {
        
        chamadas.add(funcao);
        Logger.log(`  ✓ Chamada encontrada [padrão ${patternIndex}]: ${funcao}`);
        matchesThisPattern++;
        totalMatches++;
      }
      
      // Evitar loop infinito
      if (matchesThisPattern > 50) {
        Logger.log(`Muitas chamadas encontradas com padrão ${patternIndex}, limitando...`);
        break;
      }
    }
  });
  
  const resultado = Array.from(chamadas);
  
  Logger.log(`=== RESUMO EXTRAÇÃO DE CHAMADAS ===`);
  Logger.log(`Total de matches analisados: ${totalMatches}`);
  Logger.log(`Chamadas únicas de funções do programador: ${resultado.length}`);
  Logger.log(`Funções chamadas: [${resultado.join(', ')}]`);
  
  // FALLBACK: Se não encontrou nenhuma chamada, tentar busca mais ampla
  if (resultado.length === 0 && funcoesDefinidas && funcoesDefinidas.size > 0) {
    Logger.log(`Nenhuma chamada encontrada, tentando busca mais ampla...`);
    
    // Buscar todas as funções definidas que aparecem no código
    const todasFuncoesDefinidas = Array.from(funcoesDefinidas.keys());
    todasFuncoesDefinidas.forEach(nomeFuncao => {
      // Verificar se a função aparece no código (busca simples)
      const regexFuncao = new RegExp(`\\b${nomeFuncao.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\b`, 'g');
      if (regexFuncao.test(codigoLimpo)) {
        chamadas.add(nomeFuncao);
        Logger.log(`  ✓ Chamada encontrada (busca ampla): ${nomeFuncao}`);
      }
    });
    
    return Array.from(chamadas);
  }
  
  return resultado;
}

/**
 * Gera estatísticas completas da análise
 */
function gerarEstatisticasCompletas(resultados, todosArquivos) {
  const estatisticas = {
    // Contadores básicos
    totalArquivos: todosArquivos.length,
    arquivosJS: todosArquivos.filter(a => a.isJs).length,
    totalRamificacoes: resultados.length,
    
    // Pontos de entrada
    pontosEntrada: new Set(resultados.map(r => r.pontoEntrada)).size,
    funcoesIniciais: new Set(resultados.map(r => r.funcaoInicial)).size,
    
    // Status das funções
    funcoesDefinidas: resultados.filter(r => r.status === 'definida').length,
    funcoesIndefinidas: resultados.filter(r => r.status === 'indefinida').length,
    referenciaCirculares: resultados.filter(r => r.status === 'circular').length,
    ramificacoesVazias: resultados.filter(r => r.status === 'vazia').length,
    
    // Funções duplicadas
    funcoesDuplicadas: funcoesDuplicadas.size,
    
    // Distribuição por arquivo
    distribucaoPorArquivo: {},
    
    // Funções não utilizadas (definidas mas nunca chamadas)
    funcoesNaoUtilizadas: 0,
    
    // Funções do programador vs nativas
    funcoesProgramador: funcoesDefinidas.size
  };
  
  // Calcular distribuição por arquivo
  resultados.forEach(resultado => {
    const arquivo = resultado.arquivo;
    if (!estatisticas.distribucaoPorArquivo[arquivo]) {
      estatisticas.distribucaoPorArquivo[arquivo] = 0;
    }
    estatisticas.distribucaoPorArquivo[arquivo]++;
  });
  
  // Calcular funções não utilizadas
  const funcoesUtilizadas = new Set();
  resultados.forEach(resultado => {
    if (resultado.funcaoInicial !== "[Sem chamadas]") {
      funcoesUtilizadas.add(resultado.funcaoInicial);
    }
    
    for (let i = 1; i <= 50; i++) {
      const nivel = resultado[`nivel${i}`];
      if (nivel && !nivel.includes('(circular)')) {
        funcoesUtilizadas.add(nivel);
      }
    }
  });
  
  estatisticas.funcoesNaoUtilizadas = funcoesDefinidas.size - funcoesUtilizadas.size;
  
  return estatisticas;
}


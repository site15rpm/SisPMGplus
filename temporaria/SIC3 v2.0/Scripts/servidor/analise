    'on', 'off', 'one', 'trigger', 'triggerHandler', 'bind', 'unbind', 'live', 'die', 'delegate', 'undelegate',
    'ready', 'load', 'unload', 'error', 'resize', 'scroll', 'submit', 'change', 'focus', 'blur',
    'mouseenter', 'mouseleave', 'mousedown', 'mouseup', 'mousemove', 'mouseover', 'mouseout',
    'click', 'dblclick', 'keydown', 'keyup', 'keypress',
    'ajax', 'get', 'post', 'getJSON', 'getScript', 'load', 'serialize', 'serializeArray',
    'each', 'map', 'grep', 'merge', 'unique', 'makeArray', 'inArray', 'extend', 'proxy',
    'now', 'support', 'browser', 'boxModel', 'sub', 'when', 'Deferred', 'Callbacks',
    
    // Google Apps Script nativo
    'ScriptApp', 'SpreadsheetApp', 'DocumentApp', 'DriveApp', 'GmailApp', 'CalendarApp', 'ContactsApp',
    'FormApp', 'SlidesApp', 'BigQuery', 'CardService', 'Charts', 'ContentService', 'HtmlService',
    'LockService', 'MailApp', 'Maps', 'PropertiesService', 'Session', 'Utilities', 'UrlFetchApp',
    'XmlService', 'CacheService', 'AdminDirectory', 'AdminReports', 'GroupsApp',
    

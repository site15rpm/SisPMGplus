    Logger.log(`Funções encontradas no arquivo: ${funcoes.length}`);
    
    funcoes.forEach(funcao => {
      funcoesDefinidas.set(funcao.nome, {
        nome: funcao.nome,
        arquivo: arquivoTeste.name,
        conteudo: funcao.conteudo,
        linha: funcao.linha,
        duplicadas: []
      });
    });
    
    // Buscar pontos de entrada
    const pontosEntrada = encontrarPontosEntrada(arquivoTeste.source, arquivoTeste.name);
    Logger.log(`Pontos de entrada encontrados: ${pontosEntrada.length}`);
    
    if (pontosEntrada.length === 0) {
      Logger.log("❌ Nenhum ponto de entrada encontrado!");
      return { 
        erro: "Nenhum ponto de entrada encontrado",
        funcoes: funcoes.map(f => f.nome),
        tamanhoArquivo: arquivoTeste.source.length
      };
    }
    
    // Testar extração de chamadas do primeiro ponto de entrada
    const primeiroPA = pontosEntrada[0];
    const chamadas = extrairChamadasFuncao(primeiroPA.conteudo);
    Logger.log(`Chamadas encontradas no ponto de entrada '${primeiroPA.nome}': ${chamadas.length}`);
    
    return {
      sucesso: true,
      arquivo: arquivoTeste.name,
      tamanhoArquivo: arquivoTeste.source.length,
      funcoesDefinidas: funcoes.length,
      pontosEntrada: pontosEntrada.length,
      chamadasPrimeiroPE: chamadas.length,
      detalhes: {
        funcoes: funcoes.map(f => f.nome),
        pontosEntrada: pontosEntrada.map(pe => pe.nome),
        chamadas: chamadas
      }
    };
    
  } catch (error) {
    Logger.log("❌ Erro no teste rápido: " + error);
    return { erro: error.toString() };
  }
}